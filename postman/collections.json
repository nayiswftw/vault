                  "  pm.expect(body).to.have.property('data');",
                  "  pm.expect(body.data).to.be.an('array');",
                  "  if (body.data.length > 0 && body.data[0].id) {",
                  "    pm.collectionVariables.set('sessionId', body.data[0].id);",
                  "  } else {",
                  "    const refreshToken = pm.collectionVariables.get('refreshToken');",
                  "    if (refreshToken && refreshToken.includes('.')) {",
                  "      pm.collectionVariables.set('sessionId', refreshToken.split('.')[0]);",
                  "    }",
                  "  }",
                  "});"
                ]
              }
