        {
          "name": "Login",
          "request": {
            "auth": {
              "type": "noauth"
            },
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{adminEmail}}\",\n  \"password\": \"{{adminPassword}}\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/auth/login",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "auth",
                "login"
              ]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status code is 200', function () {",
                  "  pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test('Login response has tokens', function () {",
                  "  const body = pm.response.json();",
                  "  pm.expect(body).to.have.property('accessToken');",
                  "  pm.expect(body).to.have.property('refreshToken');",
                  "  pm.collectionVariables.set('token', body.accessToken);",
                  "  pm.collectionVariables.set('refreshToken', body.refreshToken);",
                  "  if (body.refreshToken && body.refreshToken.includes('.')) {",
                  "    pm.collectionVariables.set('sessionId', body.refreshToken.split('.')[0]);",
                  "  }",
                  "  if (body.user && body.user.id) {",
                  "    pm.collectionVariables.set('userId', body.user.id);",
                  "  }",
                  "});"
                ]
              }
            }
          ]
        },
