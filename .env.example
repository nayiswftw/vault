NODE_ENV=development
PORT=3000
DATABASE_URL=postgresql://user:password@localhost:5432/finance_dashboard?sslmode=verify-full
JWT_SECRET=change_this_to_a_long_random_secret_at_least_32_chars
JWT_EXPIRES_IN=1h
JWT_REFRESH_EXPIRES_IN=7d
CORS_ORIGIN=*
THROTTLE_TTL_MS=60000
THROTTLE_LIMIT=100

# Optional seed overrides
SEED_ADMIN_EMAIL=admin@company.com
SEED_ADMIN_PASSWORD=Admin123!
SEED_ANALYST_EMAIL=analyst@company.com
SEED_ANALYST_PASSWORD=Analyst123!
SEED_VIEWER_EMAIL=viewer@company.com
SEED_VIEWER_PASSWORD=Viewer123!
